# ─── Public config (exposed to the browser — NEXT_PUBLIC_*) ─────────────────

# Base URL of the backend API, including the /api suffix (no trailing slash).
# Local dev:  http://localhost:5050/api
# Production: https://api.dilbahararomas.com/api   (recommended: api subdomain)
#         or  https://dilbahararomas.com/api       (if proxying /api on the same domain)
NEXT_PUBLIC_API_URL=http://localhost:5050/api

# Canonical public site URL (used for SEO metadata, sitemap, canonical tags).
# Local dev:  http://localhost:3000
# Production: https://dilbahararomas.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Analytics (optional; leave blank to disable) ───────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=
